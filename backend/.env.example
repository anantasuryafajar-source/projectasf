# Server
# PORT is injected by the host (Render/Railway) in production; default 3000 locally.
PORT=3000
# Allowed CORS origin(s). Comma-separate multiple (prod domain + Vercel previews):
#   FRONTEND_ORIGIN=https://ananta.vercel.app,https://ananta-git-dev.vercel.app
FRONTEND_ORIGIN=http://localhost:5173

# Supabase (server-side)
SUPABASE_URL=https://your-project-ref.supabase.co
# Service role key bypasses RLS — keep secret, server only. NEVER ship to frontend.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Chart-of-Accounts codes used by automated journals.
# These account_code values must exist in the `accounts` table.
COGS_ACCOUNT_CODE=5000
INVENTORY_ASSET_ACCOUNT_CODE=1300
# Sales invoice journal (§3.2 sales_order.shipped)
AR_ACCOUNT_CODE=1100
SALES_REVENUE_ACCOUNT_CODE=4100
VAT_OUT_ACCOUNT_CODE=2100
# Payment receipt (§3.2 payment.received): Bank/Cash account debited
PAYMENT_ACCOUNT_CODE=1000

# Tax (FR-4.1). Default Indonesian VAT rate.
VAT_RATE=0.11

# Forex gain/loss accounts (FR-1.3 month-end revaluation)
FOREX_GAIN_ACCOUNT_CODE=4800
FOREX_LOSS_ACCOUNT_CODE=6800
