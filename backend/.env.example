# Server
PORT=3000
FRONTEND_ORIGIN=http://localhost:5173

# Supabase (server-side)
SUPABASE_URL=https://your-project-ref.supabase.co
# Service role key bypasses RLS — keep secret, server only. NEVER ship to frontend.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Chart-of-Accounts codes used by the automated COGS journal (FR-3.2).
# These account_code values must exist in the `accounts` table.
COGS_ACCOUNT_CODE=5000
INVENTORY_ASSET_ACCOUNT_CODE=1300
